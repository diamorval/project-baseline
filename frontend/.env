# Browser-facing config. These are public URLs (the browser always talks to
# Keycloak and the API via localhost), so they're committed for convenience.
# docker-compose can still override them per environment.
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=baseline
VITE_KEYCLOAK_CLIENT_ID=web
VITE_API_URL=http://localhost:8000
