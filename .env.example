# ─────────────────────────────────────────────────────────────────────────────
# Baseline — environment configuration (template)
#
# Copy to .env:  `make init` does this for you, or run `cp .env.example .env`.
# The .env is loaded automatically in two places:
#   • docker compose reads the root .env for ${VAR} interpolation in
#     docker-compose.yml (so these values drive the running stack), and
#   • direnv (.envrc) exports them into your shell for local, non-Docker runs
#     (uvicorn / vite) and scripts (curl, the postgres MCP server).
#
# Every value here is a LOCAL-DEV default — convenient, not secret. Never reuse
# them in a deployed environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application database (app-db / Postgres) ─────────────────────────────────
APP_DB_USER=app
APP_DB_PASSWORD=app
APP_DB_NAME=app

# ── Backend (FastAPI) ─────────────────────────────────────────────────────────
# Full SQLAlchemy URL the backend connects with (host `app-db` on the compose
# network). Keep the credentials in sync with APP_DB_* above if you change them.
DATABASE_URL=postgresql+psycopg2://app:app@app-db:5432/app
# Internal URL (compose network) used to fetch the realm's JWKS signing keys.
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
# Public URL the browser uses — must equal the token `iss` host.
KEYCLOAK_ISSUER_URL=http://localhost:8080
KEYCLOAK_REALM=baseline
KEYCLOAK_ALGORITHM=RS256
# Audience required in the access token. Set empty ("") to disable the check.
KEYCLOAK_AUDIENCE=baseline-api
# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite — only VITE_* are exposed to the browser) ──────────────────
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=baseline
VITE_KEYCLOAK_CLIENT_ID=web
VITE_API_URL=http://localhost:8000

# ── Keycloak server ───────────────────────────────────────────────────────────
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin
# Pins Keycloak's issuer/redirect host so it matches what the browser uses.
KC_HOSTNAME=http://localhost:8080

# ── Keycloak database (keycloak-db / Postgres) ────────────────────────────────
# Used by both the keycloak-db container and Keycloak's KC_DB_* connection.
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak
KC_DB_NAME=keycloak

# ── Tooling (optional) ────────────────────────────────────────────────────────
# Host-side connection string for the postgres MCP server in .mcp.json.
# Note: libpq form (no SQLAlchemy "+psycopg2" dialect) and localhost, not app-db.
APP_DB_URL=postgresql://app:app@localhost:5432/app
